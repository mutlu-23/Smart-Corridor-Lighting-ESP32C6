// --- SensorManager Sınıfı ---
class SensorManager {
private:
  Adafruit_TSL2561_Unified tsl = Adafruit_TSL2561_Unified(TSL2561_ADDR_FLOAT, 12345);
  bool _tslOk = false;
  float _currentLux = 0.0f;
  uint16_t _rawRadarValue = 0;
  uint16_t _smoothedRadarValue = 0;
  uint32_t _lastReadTime = 0;
  const uint16_t _radarReadSamples = 5; // Gürültü azaltmak için okunacak örnek sayısı

public:
  bool begin() {
    if (!tsl.begin()) {
      Serial.println("HATA: TSL2561 bulunamadı!");
      addLog("HATA: TSL2561 bulunamadı!");
      _tslOk = false;
    } else {
      Serial.println("TSL2561 bulundu.");
      addLog("TSL2561 bulundu.");
      tsl.enableAutoRange(true); // Otomatik kazanç ayarı
      tsl.setIntegrationTime(TSL2561_INTEGRATIONTIME_101MS); // Orta hız/hassasiyet
      _tslOk = true;
    }
    // Radar pini zaten INPUT olarak ayarlandı (setupPins içinde)
    // İlk yumuşatılmış değeri okuyalım
    _smoothedRadarValue = analogRead(PIN_RADAR_AMP);
    return _tslOk; // Veya her iki sensörün de durumuna bağlı bir değer dönebilir
  }

  void update() {
    unsigned long now = millis();
    if (now - _lastReadTime >= SENSOR_READ_INTERVAL_MS) {
      _lastReadTime = now;

      // Radar okuma (ortalama alarak gürültü azaltma)
      uint32_t radarSum = 0;
      for (int i = 0; i < _radarReadSamples; i++) {
          radarSum += analogRead(PIN_RADAR_AMP);
          delayMicroseconds(50); // ADC okumaları arasında kısa bekleme
      }
      _rawRadarValue = radarSum / _radarReadSamples;


      // Radar Yumuşatma (Exponential Moving Average)
      _smoothedRadarValue = (uint16_t)((float)_rawRadarValue * RADAR_AMP_SMOOTHING + (float)_smoothedRadarValue * (1.0f - RADAR_AMP_SMOOTHING));

      // TSL Okuma
      if (_tslOk) {
        sensors_event_t event;
        tsl.getEvent(&event);
        if (event.light >= 0) { // Geçerli bir değer okunduysa
             _currentLux = event.light;
             // Serial.println("Lux: " + String(_currentLux)); // Debug
        } else {
             Serial.println("HATA: TSL2561 okuma hatası!");
             addLog("HATA: TSL2561 okuma hatası!");
             _tslOk = false; // Sensör hataya geçti
             _currentLux = 0.0f; // Hata durumunda varsayılan değer
        }
      } else {
          // TSL çalışmıyorsa, belirli aralıklarla tekrar kontrol etmeyi deneyebiliriz
          // if (now % 60000 == 0) { // Dakikada bir tekrar dene
          //   if (tsl.begin()) { _tslOk = true; /* ... */ }
          // }
           _currentLux = 0.0f; // Sensör yoksa varsayılan
      }
    }
  }

  uint16_t getRawRadarValue() const { return _rawRadarValue; }
  uint16_t getSmoothedRadarValue() const { return _smoothedRadarValue; }
  float getCurrentLux() const { return _currentLux; }
  bool isLightSensorWorking() const { return _tslOk; }

  // Mesafe Tahmini
  float calculateDistance(uint16_t amplitude, const SystemConfig& config) {
    // Önce gürültü tabanının altındaki değerleri filtrele
    if (amplitude <= config.radarNoiseFloor) {
        return -1.0f; // Gürültü seviyesinde veya altında, mesafe yok
    }

    // Kalibrasyon noktalarını kontrol et (mantıksızsa hesaplama yapma)
    // Mesafe arttıkça genlik artmalı!
    if (!(config.radarAmplitudeAt5m >= config.radarAmplitudeAt3m &&
          config.radarAmplitudeAt3m >= config.radarAmplitudeAt1m &&
          config.radarAmplitudeAt1m > config.radarNoiseFloor) ) {
      // Kalibrasyon noktaları mantıklı sırada değilse
      static uint32_t lastCalibErrorLog = 0;
      if (millis() - lastCalibErrorLog > 300000) { // 5 dakikada bir logla
          addLog("UYARI: Mesafe tahmini için radar kalibrasyonu geçersiz!");
          lastCalibErrorLog = millis();
      }
      return -1.0f; // Geçersiz kalibrasyon
    }

    // Mesafe haritalama (segment bazlı mapFloat)
    float distance = -1.0f;
    uint16_t noise = config.radarNoiseFloor;
    uint16_t amp1m = config.radarAmplitudeAt1m;
    uint16_t amp3m = config.radarAmplitudeAt3m;
    uint16_t amp5m = config.radarAmplitudeAt5m;

    // Mesafe arttıkça genliğin ARTTIĞINI varsayıyoruz.

    if (amplitude <= amp1m) { // 0-1m arası (noise ile 1m arası)
         distance = mapFloat(amplitude, noise, amp1m, 0.0f, 1.0f);
    } else if (amplitude <= amp3m) { // 1-3m arası
         distance = mapFloat(amplitude, amp1m, amp3m, 1.0f, 3.0f);
    } else if (amplitude <= amp5m) { // 3-5m arası
         distance = mapFloat(amplitude, amp3m, amp5m, 3.0f, 5.0f);
    } else { // 5m üzeri (Maksimum ölçülen genlikten büyük)
        // Burada bir ekstrapolasyon yapılabilir veya sabit bir değer (örn. 5.0m) döndürülebilir.
        // Şimdilik 5m olarak kabul edelim.
        distance = 5.0f; // Veya CORRIDOR_LENGTH_M;
    }

    // Mesafeyi koridor uzunluğu ile sınırla
    return constrain(distance, 0.0f, CORRIDOR_LENGTH_M);
  }


  // Kalibrasyon Fonksiyonları
  uint16_t calibrateNoiseFloor() {
      const int numSamples = 50;
      uint32_t sum = 0;
      Serial.println("Gürültü tabanı ölçülüyor...");
      for (int i = 0; i < numSamples; ++i) {
          sum += analogRead(PIN_RADAR_AMP);
          delay(10); // Örnekler arası bekleme
      }
      uint16_t noiseFloor = sum / numSamples;
      Serial.println("Gürültü tabanı ölçüldü: " + String(noiseFloor));
      // Yumuşatılmış değeri de güncelleyebiliriz belki? Şimdilik gerek yok.
      // _smoothedRadarValue = noiseFloor;
      return noiseFloor;
  }

  uint16_t captureCurrentAmplitude() {
    // Kalibrasyon sırasında anlık, biraz daha stabilize edilmiş değeri almak iyi olabilir.
    // update() içindeki yumuşatılmış değeri kullanalım.
    // Veya burada da birkaç okuma yapıp ortalama alabiliriz.
    // Şimdilik smoothed değeri dönelim.
    Serial.println("Anlık yumuşatılmış genlik yakalandı: " + String(_smoothedRadarValue));
    return _smoothedRadarValue;
  }
};

// --- LedControl Sınıfı ---
class LedControl {
private:
    CRGB* _leds = nullptr;
    int _numLeds = 0;
    uint32_t _lastEffectUpdateTime = 0;
    uint8_t _theaterChaseOffset = 0; // Tiyatro efekti için
    uint8_t _pulseBrightness = 0;     // Nabız efekti için
    bool _pulseDirection = true;      // Nabız yönü (artıyor/azalıyor)

public:
    void begin(CRGB* leds, int numLeds) {
        _leds = leds;
        _numLeds = numLeds;
        if (_leds == nullptr || _numLeds <= 0) {
             addLog("KRİTİK HATA: LedControl.begin geçersiz parametreler!");
        }
    }

    // Tüm LED'leri belirli bir ölçekte karartır
    void fadeToBlack(uint8_t scale = 40) {
        if (!_leds) return;
        fadeToBlackBy(_leds, _numLeds, scale);
    }

    //--- Efekt Fonksiyonları ---

    // Basit: Belirli bir pozisyon etrafındaki segmenti yakar
    void simpleEffect(float position, uint16_t segmentLength, CHSV color) {
        if (!_leds || _numLeds <= 0) return;
        fadeToBlack(50); // Önceki izleri biraz söndür
        int centerLed = round(position);
        int startLed = safe_max(0, centerLed - (int)(segmentLength / 2)); // Cast to int for safety
        int endLed = safe_min(_numLeds - 1, centerLed + (int)(segmentLength / 2)); // Cast to int
        for (int i = startLed; i <= endLed; ++i) {
             // Check bounds just in case
             if (i >= 0 && i < _numLeds) {
                 _leds[i] = color;
             }
        }
    }

    // İz Efekti: Yanan segmentin arkasında sönük bir iz bırakır
    void trailEffect(float position, uint16_t segmentLength, CHSV color) {
        if (!_leds || _numLeds <= 0) return;
        fadeToBlack(30); // Daha yavaş söndürerek iz bırak
        simpleEffect(position, segmentLength, color); // Ana segmenti yak
    }

    // Nabız Efekti: Segmentin parlaklığı artıp azalır
    void pulseEffect(float position, uint16_t segmentLength, CHSV baseColor) {
        if (!_leds || _numLeds <= 0) return;
        fadeToBlack(50);
        int centerLed = round(position);
        int startLed = safe_max(0, centerLed - (int)(segmentLength / 2));
        int endLed = safe_min(_numLeds - 1, centerLed + (int)(segmentLength / 2));

        // Parlaklığı güncelle (sinüs dalgası gibi)
        uint32_t now = millis();
        if (now - _lastEffectUpdateTime > 20) { // Nabız hızı
            _lastEffectUpdateTime = now;
             // Basit artış/azalış
            if (_pulseDirection) {
                 _pulseBrightness = safe_min((uint8_t)250, (uint8_t)(_pulseBrightness + 5)); // Use safe_min/max
                 if (_pulseBrightness >= 250) _pulseDirection = false;
            } else {
                 _pulseBrightness = safe_max((uint8_t)10, (uint8_t)(_pulseBrightness - 5)); // Use safe_min/max
                 if (_pulseBrightness <= 10) _pulseDirection = true;
            }
             // _pulseBrightness = constrain(_pulseBrightness, 10, 250); // constrain is also fine
        }

        CHSV pulseColor = baseColor;
        pulseColor.v = _pulseBrightness; // Parlaklığı ayarla

        for (int i = startLed; i <= endLed; ++i) {
             if (i >= 0 && i < _numLeds) { // Bounds check
                 _leds[i] = pulseColor;
             }
        }
    }

    // Gökkuşağı Segmenti: Belirtilen segmenti gökkuşağı renklerinde yakar
    void rainbowEffect(float position, uint16_t segmentLength) {
        if (!_leds || _numLeds <= 0) return;
        fadeToBlack(60);
        int centerLed = round(position);
        int startLed = safe_max(0, centerLed - (int)(segmentLength / 2));
        int endLed = safe_min(_numLeds - 1, centerLed + (int)(segmentLength / 2));
        int numToFill = endLed - startLed + 1;

        if (numToFill > 0 && startLed < _numLeds) {
            uint8_t initialHue = (millis() / 20) % 256; // Zamanla değişen başlangıç rengi
            // Ensure we don't write past the end of the array
            numToFill = safe_min(numToFill, _numLeds - startLed);
            fill_rainbow(&(_leds[startLed]), numToFill, initialHue, 7); // 7 hue adımı
        }
    }

    // Tiyatro Takibi: Segment içinde koşan ışıklar
    void theaterChaseEffect(float position, uint16_t segmentLength, CHSV color) {
        if (!_leds || _numLeds <= 0) return;
        fadeToBlack(60); // Önceki durumu temizle/söndür

        int centerLed = round(position);
        int startLed = safe_max(0, centerLed - (int)(segmentLength / 2));
        int endLed = safe_min(_numLeds - 1, centerLed + (int)(segmentLength / 2));

        uint32_t now = millis();
         // Efekt hızını ayarlamak için _lastEffectUpdateTime kullanılır
        if (now - _lastEffectUpdateTime > 100) { // Koşma hızı (ms)
            _theaterChaseOffset = (_theaterChaseOffset + 1) % 3; // 3 adımda bir tekrar et
            _lastEffectUpdateTime = now;
        }

        for (int i = startLed; i <= endLed; i++) {
            if (i >= 0 && i < _numLeds) { // Bounds check
                if ((i % 3) == _theaterChaseOffset) {
                    _leds[i] = color; // Her 3 LED'den birini yak
                } else {
                    _leds[i] = CRGB::Black; // Diğerlerini söndür (fadeToBlack zaten yaptı ama garanti olsun)
                }
            }
        }
    }
};

