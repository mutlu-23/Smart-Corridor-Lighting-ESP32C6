}
// ========== SENSÖR FONKSİYONLARI ==========
void IRAM_ATTR sensorInterrupt() {
  static unsigned long lastInterrupt = 0;
  unsigned long currentTime = micros();
  if (currentTime - lastInterrupt > 50000) {
    motionInterrupt = true;
    lastInterruptTime = millis();
  }
  lastInterrupt = currentTime;
}
void readAnalogSensor() {
  if (millis() - lastAnalogReadTime < ANALOG_READ_INTERVAL) return;
  lastAnalogReadTime = millis();
  uint16_t sensorValue = analogRead(SENSOR_ANALOG_PIN);
  analogSamples[sampleIndex] = sensorValue;
  sampleIndex = (sampleIndex + 1) % SAMPLE_BUFFER_SIZE;
  uint32_t sum = 0;
  analogMax = 0;
  for (int i = 0; i < SAMPLE_BUFFER_SIZE; i++) {
    sum += analogSamples[i];
    if (analogSamples[i] > analogMax) {
      analogMax = analogSamples[i];
    }
  }
  analogAverage = sum / SAMPLE_BUFFER_SIZE;
  bool newMovementDetected = (analogMax > movementThreshold) && 
                            (analogMax > analogAverage * 1.3);
  if (newMovementDetected && !movementDetected) {
    movementStartTime = millis();
    movementDetected = true;
    lastMotionTime = millis();
    if (!ledsActive) {
      ledsActive = true;
      ledsActivatedAt = millis();
      Serial.println("LED aktif: analog tetikleme, zamanlayıcı başlatıldı.");
    }
  }
  else if (!newMovementDetected && movementDetected) {
    movementDetected = false;
  }
}
void processSensor() {
  if (millis() - lastSensorProcessTime < 50) return;
  lastSensorProcessTime = millis();
  readAnalogSensor();
  if (motionInterrupt) {
    motionInterrupt = false;
    if (analogMax > movementThreshold / 2) {
      lastMotionTime = millis();
      if (!ledsActive) {
        ledsActive = true;
        ledsActivatedAt = millis();
        Serial.println("LED aktif: interrupt tetikleme, zamanlayıcı başlatıldı.");
      }
    }
  }
    // ---- Maksimum sürekli çalışma süresi kontrolü ----
  if (ledsActive && ledsActivatedAt != 0) {
    if ((millis() - ledsActivatedAt) >= MAX_RUN_MS) {
      ledsActive = false;
      ledsActivatedAt = 0;
      fill_solid(leds, NUM_LEDS, CRGB::Black);
      FastLED.show();
      Serial.println("Maksimum çalışma süresi doldu -> LED kapatıldı.");
    }
  }
  if (calibrating) {
    if (millis() - calibrationStartTime < 10000) {
      if (analogMax > noiseLevel) {
        noiseLevel = analogMax;
      }
    } else {
      calibrating = false;
      // ✅ Kalibrasyon düzeltmesi: güvenli float çarpım + yuvarlama + sınırlandırma
      movementThreshold = constrain((uint16_t)((float)noiseLevel * 1.1f + 0.5f), 10, 4095);
      sensitivity = map(movementThreshold, 10, 4095, 100, 0); // yüksek eşik = düşük hassasiyet
      preferences.putUShort("threshold", movementThreshold);
      preferences.putUChar("sensitivity", sensitivity);
    }
    return;
  }
  if (ledsActive && !movementDetected && (millis() - lastMotionTime > holdTime)) {
    ledsActive = false;
    fill_solid(leds, NUM_LEDS, CRGB::Black);
    FastLED.show();
  }
}
// ========== WEB SUNUCU FONKSİYONLARI ==========
void handleAPI(AsyncWebServerRequest *request) {
  String path = request->url();
  if (path.startsWith("/api/anim")) {
    if (request->hasParam("value")) {
      currentAnimation = request->getParam("value")->value().toInt();
      preferences.putUChar("animation", currentAnimation);
      request->send(200, "text/plain", "OK");
    }
  }
  else if (path.startsWith("/api/brightness")) {
    if (request->hasParam("value")) {
      currentBrightness = request->getParam("value")->value().toInt();
      FastLED.setBrightness(currentBrightness * 2.55);
      preferences.putUChar("brightness", currentBrightness);
      request->send(200, "text/plain", "OK");
    }
  }
  else if (path.startsWith("/api/speed")) {
    if (request->hasParam("value")) {
      currentSpeed = request->getParam("value")->value().toInt();
      preferences.putUChar("speed", currentSpeed);
      request->send(200, "text/plain", "OK");
    }
  }
  else if (path.startsWith("/api/color")) {
    if (request->hasParam("value")) {
      String colorStr = request->getParam("value")->value();
      currentColor = strtol(colorStr.c_str(), NULL, 16);
      preferences.putULong("color", currentColor);
      request->send(200, "text/plain", "OK");
    }
  }
  else if (path.startsWith("/api/holdtime")) {
    if (request->hasParam("value")) {
      holdTime = request->getParam("value")->value().toInt() * 1000;
      preferences.putUShort("holdTime", holdTime / 1000);
      request->send(200, "text/plain", "OK");
    }
  }
  else if (path.startsWith("/api/sensitivity")) {
    if (request->hasParam("value")) {
      sensitivity = request->getParam("value")->value().toInt();
      movementThreshold = map(sensitivity, 0, 100, 10, 50);
      preferences.putUChar("sensitivity", sensitivity);
      preferences.putUShort("threshold", movementThreshold);
      request->send(200, "text/plain", "OK");
    }
  }
  else if (path.startsWith("/api/calibrate")) {
    calibrating = true;
    calibrationStartTime = millis();
    noiseLevel = 0;
    request->send(200, "text/plain", "Kalibrasyon başlatıldı");
  }
  else if (path.startsWith("/api/status")) {
    StaticJsonDocument<300> doc;
    doc["animation"] = currentAnimation;
    doc["brightness"] = currentBrightness;
    doc["speed"] = currentSpeed;
    doc["color"] = currentColor;
    doc["holdTime"] = holdTime / 1000;
    doc["sensitivity"] = sensitivity;
    doc["lastMotion"] = lastMotionTime;
    doc["ledsActive"] = ledsActive;
    doc["sensorValue"] = analogMax;
    doc["threshold"] = movementThreshold;
    String response;
    serializeJson(doc, response);
    request->send(200, "application/json", response);
  }
  else {
    request->send(404, "text/plain", "Not Found");
  }
}
void handleDoUpdate(AsyncWebServerRequest *request, const String& filename, size_t index, uint8_t *data, size_t len, bool final) {
  // ✅ OTA güvenliği: otaInProgress başta true yapılıyor
  if (!index) {
    otaInProgress = true;
    Serial.println("OTA Güncelleme Başlıyor");
    if (!Update.begin(UPDATE_SIZE_UNKNOWN)) {
      Update.printError(Serial);
      otaInProgress = false; // hata varsa false
      return;
    }
  }
  if (len) {
    if (Update.write(data, len) != len) {
      Update.printError(Serial);
      otaInProgress = false;
      return;
    }
  }
  if (final) {
    if (Update.end(true)) {
      Serial.println("OTA Güncelleme Tamamlandı");
      otaInProgress = false;
      request->send(200, "text/plain", "Güncelleme Başarılı. Cihaz yeniden başlatılıyor...");
      delay(1000);
      ESP.restart();
    } else {
      Update.printError(Serial);
      otaInProgress = false;
      request->send(500, "text/plain", "Güncelleme Başarısız");
    }
  }
}
void startWebServer() {
  server.on("/", HTTP_GET, [](AsyncWebServerRequest *request) {
    String html = index_html;
    html.replace("%WIFISTATUS%", WiFi.status() == WL_CONNECTED ? "Bağlı" : "Bağlı Değil");
    html.replace("%IPADDRESS%", WiFi.localIP().toString());
    html.replace("%CHIPID%", String((uint32_t)ESP.getEfuseMac(), HEX));
    html.replace("%FREEHEAP%", String(ESP.getFreeHeap() / 1024));
    request->send(200, "text/html", html);
  });
  server.on("/ota", HTTP_GET, [](AsyncWebServerRequest *request) {
    request->send(200, "text/html", ota_html);
  });
  server.on("/doUpdate", HTTP_POST, 
    [](AsyncWebServerRequest *request) {},
    handleDoUpdate
  );
  server.on("/api/anim", HTTP_GET, handleAPI);
  server.on("/api/brightness", HTTP_GET, handleAPI);
  server.on("/api/speed", HTTP_GET, handleAPI);
  server.on("/api/color", HTTP_GET, handleAPI);
  server.on("/api/holdtime", HTTP_GET, handleAPI);
  server.on("/api/sensitivity", HTTP_GET, handleAPI);
  server.on("/api/calibrate", HTTP_GET, handleAPI);
  server.on("/api/status", HTTP_GET, handleAPI);
  server.begin();
  webServerStarted = true;
  Serial.println("Web sunucusu başlatıldı");
  Serial.print("IP Adresi: ");
  Serial.println(WiFi.localIP());
}
void safeRestart(const char *reason) {
  Serial.printf("SAFE RESTART: %s\n", reason);
  if (otaInProgress) {
    Serial.println("OTA işlemi sürüyor, yeniden başlatma atlandı.");
    return;
  }
  preferences.end();
  TimeBrightnessManager.endPreferences();
  // 3) Web sunucusunu düzgün kapat
  if (webServerStarted) {
    Serial.println("Web sunucusu kapatılıyor...");
    server.end();
    webServerStarted = false;
  }
  if (leds != nullptr) {
    fill_solid(leds, NUM_LEDS, CRGB::Black);
    FastLED.show();
    delay(50); 
  }
  if (WiFi.status() == WL_CONNECTED) {
    WiFi.disconnect(true);
  }
  delay(200);
  ESP.restart();
}
// ========== ANA KURULUM ve DÖNGÜ ==========
void setup() {
  Serial.begin(115200);
  preferences.begin("light-control", false);
  currentAnimation = preferences.getUChar("animation", DEFAULT_ANIMATION);
  currentBrightness = preferences.getUChar("brightness", DEFAULT_BRIGHTNESS);
  currentSpeed = preferences.getUChar("speed", DEFAULT_SPEED);
  currentColor = preferences.getULong("color", CRGB::White);
  holdTime = preferences.getUShort("holdTime", DEFAULT_HOLD_TIME) * 1000;
  sensitivity = preferences.getUChar("sensitivity", DEFAULT_SENSITIVITY);
  movementThreshold = preferences.getUShort("threshold", MOVEMENT_THRESHOLD);
  leds = (CRGB*)malloc(NUM_LEDS * sizeof(CRGB));
  if (!leds) {
    Serial.println("Bellek ayırma hatası!");
    while(1) delay(1000);
  }
  FastLED.addLeds<SK6812, LED_PIN, GRB>(leds, NUM_LEDS);
  FastLED.setBrightness(currentBrightness * 2.55);
  fill_solid(leds, NUM_LEDS, CRGB::Black);
  FastLED.show();
  pinMode(SENSOR_DIGITAL_PIN, INPUT);
  pinMode(SENSOR_ANALOG_PIN, INPUT);
  attachInterrupt(digitalPinToInterrupt(SENSOR_DIGITAL_PIN), sensorInterrupt, RISING);
  memset(analogSamples, 0, sizeof(analogSamples));
  WiFi.begin(ssid, password);
  Serial.print("WiFi'ye bağlanıyor");
  unsigned long wifiStartTime = millis();
  while (WiFi.status() != WL_CONNECTED && millis() - wifiStartTime < 10000) {
    delay(500);
    Serial.print(".");
  }
  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\nWiFi bağlandı");
    startWebServer();
  } else {
    Serial.println("\nWiFi bağlantısı başarısız. Web arayüzü devre dışı.");
  }
  TimeBrightnessManager.begin();
  Serial.println("Kurulum tamamlandı");
  Serial.printf("Hareket eşik değeri: %d\n", movementThreshold);
  Serial.printf("Hassasiyet: %d%%\n", sensitivity);
}
void loop() {
  reconnectWiFi();
  processSensor();
  if (ledsActive) {
    updateAnimation();
  }
  if (millis() - lastStatusUpdateTime > 10000) {
    lastStatusUpdateTime = millis();
    Serial.printf("Sensör: %d, Eşik: %d, Hareket: %s\n", 
                 analogMax, movementThreshold, movementDetected ? "Evet" : "Hayır");
  }
  TimeBrightnessManager.loop();
  delay(1);
}
// WiFi yeniden bağlanma fonksiyonu
void reconnectWiFi() {
  static unsigned long lastReconnectAttempt = 0;
  const unsigned long reconnectInterval = 30000; // 30 saniyede bir dene
  if (WiFi.status() != WL_CONNECTED) {
    unsigned long currentTime = millis();
    // Belirli aralıklarla yeniden bağlanmayı dene
    if (currentTime - lastReconnectAttempt >= reconnectInterval) {
      Serial.println("WiFi bağlantısı koptu! Yeniden bağlanılıyor...");
      WiFi.disconnect();
      delay(1000);
      WiFi.begin(ssid, password);
      lastReconnectAttempt = currentTime;
      // 10 saniye içinde bağlanıp bağlanamadığını kontrol et
      unsigned long startTime = millis();
      while (WiFi.status() != WL_CONNECTED && millis() - startTime < 10000) {
        delay(500);
        Serial.print(".");
      }
      if (WiFi.status() == WL_CONNECTED) {
        Serial.println("\nWiFi yeniden bağlandı!");
        Serial.print("IP Adresi: ");
        Serial.println(WiFi.localIP());
        // Web sunucusunu yeniden başlat
        if (webServerStarted) {
          server.end();
        }
        startWebServer();
      } else {
        Serial.println("\nYeniden bağlanma başarısız!");
      }
    }
  }
}
