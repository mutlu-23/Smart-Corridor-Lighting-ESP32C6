// Arduino max/min makroları bazen std::max/min ile çakışabilir.
// İhtiyaç olursa diye explicit std:: kullanımı için veya kendi makromuzu tanımlamak için:
template<typename T> T safe_max(T a, T b) { return (a > b) ? a : b; }
template<typename T> T safe_min(T a, T b) { return (a < b) ? a : b; }


