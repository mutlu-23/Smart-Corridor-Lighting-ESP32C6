// ==================== SETUP ====================
void setup() {
    Serial.begin(115200);
    while (!Serial && millis() < 2000);
    Serial.println("\n\nKoridor Aydinlatma Sistemi v" APP_VERSION " - ESP32-C6");

    if (NUM_LEDS <= 0) { Serial.println("HATA: NUM_LEDS > 0 olmalı!"); addLog("KRİTİK HATA: NUM_LEDS > 0 olmalı!"); while(1) delay(1000); }

    setupPins();
    setupLittleFS();

    if (!loadConfiguration()) {
        addLog("UYARI: Ayar dosyasi bulunamadi. Varsayilanlar kullaniliyor.");
        if (!saveConfiguration()) {
            addLog("HATA: Varsayilan ayarlar kaydedilemedi!");
        }
    }
    else {
        addLog("Ayarlar " + String(CONFIG_FILE_PATH) + " dosyasindan yuklendi.");
    }

    // SensorManager.begin() çağrısı setupSensors içine taşındı
    setupSensors();

    // LedControl.begin() çağrısı setupFastLED içine taşındı
    setupFastLED();

    // setAllLEDs(CRGB::Black); // setupFastLED içinde yapıldı

    if (!setupWiFi()) {
        setupAPMode();
    }

    setupWebSockets();
    setupWebServer();
    server.begin();
    addLog("Web Sunucusu başlatildi.");

    if (state.wifiConnected) {
        setupOTA();
    }
    else {
        addLog("UYARI: AP Modunda, ArduinoOTA başlatılmadı.");
    }

    addLog("Sistem kurulumu tamamlandi.");
    state.lastMotionDetectedTime = millis() - MOTION_TIMEOUT_MS - 1000; // Başlangıçta hareket yok say
}

// ==================== ANA DÖNGÜ ====================
void loop() {
    unsigned long currentTime = millis();

    checkWifiConnection(); // WiFi bağlantısını kontrol et/yeniden bağlanmayı dene
    if (state.wifiConnected) {
        ArduinoOTA.handle(); // OTA güncellemelerini dinle
    }

    ws.cleanupClients(); // WebSocket bağlantılarını temizle

    sensorManager.update(); // Sensörleri güncelle (içinde zaman kontrolü var)
    processRadar();         // Radarı işle (sensör verilerini kullanır)

    updateSystemState();    // Genel sistem durumunu güncelle (ışık seviyesi, modlar vs.)

    updateLeds();           // LED'leri güncelle (sistem durumuna ve efektlere göre, içinde zaman kontrolü var)

    // Periyodik WebSocket durum güncellemesi
    if (currentTime - state.lastWsUpdateTime >= WEBSOCKET_UPDATE_INTERVAL_MS) {
        sendWsUpdate();
        state.lastWsUpdateTime = currentTime;
    }

    // WDT beslemesi (eğer aktif edilecekse)
    // esp_task_wdt_reset();

    delay(1); // Diğer görevlere zaman tanımak için küçük bir gecikme
}

