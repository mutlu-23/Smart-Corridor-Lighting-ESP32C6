// ========== ZAMAN ve PARLAKLIK YÖNETİCİSİ SINIFI ==========
class TimeBrightnessManager {
private:
    // Zaman / sync
    unsigned long lastNTPSyncTime = 0;
    unsigned long lastBrightnessCheckTime = 0;
    unsigned long lastMillisAtSync = 0;   
    time_t lastSyncedTime = 0;            
    bool timeSynced = false;
    bool initialTimeSet = false;
    unsigned long nightlyRestartPendingAt = 0; 
    bool restartChecked = false;
    uint8_t currentAppliedBrightness = 0;
    bool isNightMode = false;
    Preferences timePreferences;
    // --- Yardımcı metotlar ---
    bool syncTimeWithNTP() {
        Serial.println("🕒 NTP ile zaman senkronizasyonu deneniyor...");
        configTime(GMT_OFFSET_SEC, DAYLIGHT_OFFSET_SEC, NTP_SERVER1, NTP_SERVER2, NTP_SERVER3);
        unsigned long start = millis();
        const unsigned long timeout = 10000; // 10 saniye timeout
        while (millis() - start < timeout) {
            time_t now = time(nullptr);
            if (now > 100000) {
                lastSyncedTime = now;
                lastMillisAtSync = millis();
                timeSynced = true;
                initialTimeSet = true;
                timePreferences.putULong("lastTime", (unsigned long)lastSyncedTime);
                timePreferences.putULong("lastMillis", lastMillisAtSync);
                struct tm timeinfo;
                localtime_r(&now, &timeinfo);
                Serial.printf("✅ Zaman senkronize edildi: %02d:%02d:%02d %02d.%02d.%04d\n",
                             timeinfo.tm_hour, timeinfo.tm_min, timeinfo.tm_sec,
                             timeinfo.tm_mday, timeinfo.tm_mon + 1, timeinfo.tm_year + 1900);
                return true;
            }
            delay(100); // kısa bekleme, bloklayıcı değil
        }
        Serial.println("❌ Zaman senkronizasyonu başarısız");
        return false;
    }
    void updateInternalTime() {
        if (!timeSynced || !initialTimeSet) return;
        unsigned long currentMillis = millis();
        unsigned long elapsed = (unsigned long)(currentMillis - lastMillisAtSync); 
        unsigned long secs = elapsed / 1000UL;
        if (secs > 0) {
            lastSyncedTime += (time_t)secs;
            lastMillisAtSync = lastMillisAtSync + secs * 1000UL;
        }
    }
    time_t parseCompileTimeFallback() {
        const char *months[] = {"Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"};
        char monthStr[4] = {0};
        int day = 0, year = 0;
        int hour = 0, minute = 0, second = 0;
        if (sscanf(__DATE__, "%3s %d %d", monthStr, &day, &year) != 3) return 0;
        if (sscanf(__TIME__, "%d:%d:%d", &hour, &minute, &second) != 3) return 0;
        int mon = -1;
        for (int i = 0; i < 12; ++i) {
            if (strcmp(monthStr, months[i]) == 0) { mon = i; break; }
        }
        if (mon < 0) return 0;
        struct tm tmv;
        memset(&tmv, 0, sizeof(tmv));
        tmv.tm_mday = day;
        tmv.tm_mon  = mon;
        tmv.tm_year = year - 1900;
        tmv.tm_hour = hour;
        tmv.tm_min  = minute;
        tmv.tm_sec  = second;
        time_t ct = mktime(&tmv);
        if (ct > 0) ct += GMT_OFFSET_SEC; 
        return ct;
    }
    time_t getCurrentTime() {
        if (!timeSynced || !initialTimeSet) {
            if (lastSyncedTime > 0) {
                updateInternalTime();
                return lastSyncedTime;
            }
            time_t ct = parseCompileTimeFallback();
            return ct; 
        }
        updateInternalTime();
        return lastSyncedTime;
    }
    bool isNightTime(time_t now) {
        struct tm timeinfo;
        localtime_r(&now, &timeinfo);
        int h = timeinfo.tm_hour;
        int m = timeinfo.tm_min;
        // Gece aralığı: 23:00 -> 06:30
        if (h > NIGHT_START_HOUR) return true;                
        if (h < NIGHT_END_HOUR) return true;                  
        if (h == NIGHT_END_HOUR && m < NIGHT_END_MINUTE) return true;
        if (h == NIGHT_START_HOUR && m >= NIGHT_START_MINUTE) return true;
        return false;
    }
    uint8_t calculateTargetBrightness(time_t now) {
        return isNightTime(now) ? NIGHT_BRIGHTNESS : DAY_BRIGHTNESS;
    }
    void applyBrightnessBasedOnTime() {
        time_t currentTime = getCurrentTime();
        if (currentTime == 0) {
            Serial.println("⏰ Zaman bilgisi yok, parlaklık güncellenemedi");
            return;
        }
        uint8_t targetBrightness = calculateTargetBrightness(currentTime);
        bool newNightMode = isNightTime(currentTime);
        if (targetBrightness != currentAppliedBrightness || newNightMode != isNightMode) {
            currentAppliedBrightness = targetBrightness;
            isNightMode = newNightMode;
            extern uint8_t currentBrightness; 
            currentBrightness = targetBrightness;
            FastLED.setBrightness((int)targetBrightness * 255 / 100); 
            struct tm timeinfo;
            localtime_r(&currentTime, &timeinfo);
            Serial.printf("💡 Parlaklık güncellendi: %s modu, %d%%, Saat: %02d:%02d\n",
                         isNightMode ? "Gece" : "Gündüz", targetBrightness,
                         timeinfo.tm_hour, timeinfo.tm_min);
        }
    }
    void checkScheduledRestart() {
        time_t currentTime = getCurrentTime();
        if (currentTime == 0) return;
        struct tm timeinfo;
        localtime_r(&currentTime, &timeinfo);
        if (timeinfo.tm_hour == RESTART_HOUR && timeinfo.tm_min == RESTART_MINUTE) {
            if (!restartChecked) {
                restartChecked = true;
                nightlyRestartPendingAt = millis() + 10000UL; 
                Serial.println("🔄 Gece restartı planlandı (02:00) — 10s bekleniyor");
            }
        } else {
            restartChecked = false;
            nightlyRestartPendingAt = 0;
        }
        if (nightlyRestartPendingAt != 0 && (long)(millis() - nightlyRestartPendingAt) >= 0) {
            nightlyRestartPendingAt = 0;
            Serial.println("🔁 Gece restart zamanı geldi, safeRestart çağrılıyor");
            safeRestart("nightly 02:00");
        }
    }
public:
    TimeBrightnessManager() {
    }
    void endPreferences() {
        timePreferences.end();
    }
    void begin() {
        Serial.println("⏰ TimeBrightnessManager başlatılıyor...");
        timePreferences.begin("time-bright", false);
        lastSyncedTime = (time_t)timePreferences.getULong("lastTime", 0);
        lastMillisAtSync = timePreferences.getULong("lastMillis", 0);
        if (lastSyncedTime > 0) {
            timeSynced = true;
            initialTimeSet = true;
            Serial.printf("📅 Önceki zaman yüklendi: %s", ctime(&lastSyncedTime));
        }
        lastNTPSyncTime = millis();
        if (WiFi.status() == WL_CONNECTED) {
            if (syncTimeWithNTP()) {
                Serial.println("✅ İlk NTP senkronizasyonu başarılı");
            } else {
                Serial.println("❌ İlk NTP senkronizasyonu başarısız, offline modda devam");
            }
        } else {
            Serial.println("🌐 WiFi bağlı değil, offline zaman kullanılacak");
        }
        applyBrightnessBasedOnTime();
        Serial.println("✅ TimeBrightnessManager başlatma tamamlandı");
    }
    void loop() {
        unsigned long currentMillis = millis();
        if (WiFi.status() == WL_CONNECTED) {
            if (!timeSynced || (long)(currentMillis - lastNTPSyncTime) >= (long)NTP_SYNC_INTERVAL) {
                if (syncTimeWithNTP()) {
                    Serial.println("✅ Periyodik NTP senkronizasyonu başarılı");
                }
                lastNTPSyncTime = currentMillis;
            }
        }
        updateInternalTime();
        if ((long)(currentMillis - lastBrightnessCheckTime) >= (long)BRIGHTNESS_CHECK_INTERVAL) {
            applyBrightnessBasedOnTime();
            lastBrightnessCheckTime = currentMillis;
        }
        checkScheduledRestart();
    }
    bool isTimeSynced() const { return timeSynced; }
    time_t getCurrentTimestamp() { return getCurrentTime(); }
    String getCurrentTimeString() {
        time_t now = getCurrentTime();
        if (now == 0) return String("Zaman bilgisi yok");
        struct tm timeinfo;
        localtime_r(&now, &timeinfo);
        char buffer[32];
        strftime(buffer, sizeof(buffer), "%H:%M:%S %d.%m.%Y", &timeinfo);
        return String(buffer);
    }
    bool isCurrentlyNight() const { return isNightMode; }
    uint8_t getCurrentBrightnessLevel() const { return currentAppliedBrightness; }
};
