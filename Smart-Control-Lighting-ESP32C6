// ========== ANİMASYON FONKSİYONLARI ==========
void animationSolid() {
  fill_solid(leds, NUM_LEDS, currentColor);
}
void animationPulse() {
  static uint32_t lastUpdate = 0;
  uint32_t now = millis();
  int interval = 40 - (int)currentSpeed;
  if (interval < 8) interval = 8;
  if (now - lastUpdate > (uint32_t)interval) {
    lastUpdate = now;
    uint8_t wave = sin8((uint32_t)(now >> 2) + ((uint32_t)currentSpeed * 4U));
    uint8_t brightness = scale8(wave, (uint8_t)(currentBrightness * 2.55));
    uint8_t setB = (brightness < 1 ? 1 : brightness);
    fill_solid(leds, NUM_LEDS, currentColor);
    FastLED.setBrightness(setB);
    int mid = NUM_LEDS / 2;
    for (int i = 0; i < NUM_LEDS; i++) {
      int d = abs(i - mid);
      uint8_t fall = qsub8(255, (uint8_t)((d * 255) / (mid ? mid : 1)));
      leds[i].nscale8_video(fall);
    }
  }
}
void animationTheaterChase() {
  static uint32_t lastUpdate = 0;
  static uint8_t j = 0;
  uint32_t now = millis();
  int speedDelay = max(10, 120 - currentSpeed * 2);
  if (now - lastUpdate > (uint32_t)speedDelay) {
    lastUpdate = now;
    j++;
    CHSV hsv = rgb2hsv_approximate(currentColor);
    CHSV hsv2 = hsv;
    hsv2.h = hsv.h + 32;
    for (int i = 0; i < NUM_LEDS; i++) {
      uint8_t pattern = (i + j) % 6;
      if (pattern < 2) {
        leds[i] = CHSV(hsv.h, 255, qmul8((uint8_t)(currentBrightness * 2.55), 200));
      } else if (pattern < 4) {
        leds[i] = CHSV(hsv2.h, 200, qmul8((uint8_t)(currentBrightness * 2.55), 160));
      } else {
        leds[i] = CRGB::Black;
      }
    }
  }
}
void animationRainbow() {
  static uint32_t lastUpdate = 0;
  static uint16_t baseHue = 0;
  uint32_t now = millis();
  if (now - lastUpdate > max(4, 40 - currentSpeed)) {
    lastUpdate = now;
    baseHue += 2 + (currentSpeed / 8);
    for (int i = 0; i < NUM_LEDS; i++) {
      uint8_t hue = (uint8_t)(baseHue + (i * 256 / max(1, NUM_LEDS / 2)));
      uint8_t sat = 220 - (sin8(i * 2 + (now >> 4)) / 4);
      uint8_t val = qmul8((uint8_t)(currentBrightness * 2.55), 255);
      leds[i] = CHSV(hue, sat, val);
    }
    FastLED.setBrightness(max(1, (int)(currentBrightness * 2.55)));
  }
}
void animationLarsonScanner() {
  static uint32_t lastUpdate = 0;
  static int8_t direction = 1;
  static int16_t pos = 0;
  uint32_t now = millis();
  if (now - lastUpdate > max(4, 50 - currentSpeed)) {
    lastUpdate = now;
    CHSV baseHSV = rgb2hsv_approximate(currentColor);
    for (int i = 0; i < NUM_LEDS; i++) {
      leds[i].nscale8_video(250); 
    }
    pos += direction;
    if (pos >= NUM_LEDS - 1) direction = -1;
    if (pos <= 0) direction = 1;
    leds[pos] = CHSV(baseHSV.h, 255, currentBrightness * 2.55);
    if (pos > 0)  leds[pos-1] = CHSV(baseHSV.h, 200, max(1, (int)(currentBrightness * 2.55 * 0.6)));
    if (pos < NUM_LEDS-1) leds[pos+1] = CHSV(baseHSV.h, 200, max(1, (int)(currentBrightness * 2.55 * 0.6)));
    if (pos > 1)  leds[pos-2].nscale8_video(150);
    if (pos < NUM_LEDS-2) leds[pos+2].nscale8_video(150);
  }
}
void animationComet() {
  static uint32_t lastUpdate = 0;
  static uint16_t pos = 0;
  uint32_t now = millis();
  if (now - lastUpdate > max(6, 40 - currentSpeed)) {
    lastUpdate = now;
    uint8_t tailLen = constrain(4 + currentSpeed / 4, 4, 24);
    for (int i = 0; i < NUM_LEDS; i++) leds[i].nscale8_video(240);
    pos = (pos + 1) % NUM_LEDS;
    leds[pos] = currentColor;
    for (int t = 1; t <= tailLen; t++) {
      int idx = pos - t;
      if (idx < 0) idx += NUM_LEDS;
      uint8_t fade = 255 - (uint8_t)( (255.0 * t) / tailLen );
      CRGB c = currentColor;
      c.nscale8_video(fade);
      leds[idx] = leds[idx] + c; 
      leds[idx].nscale8_video(220 - min(200, t*6));
    }
    FastLED.setBrightness(currentBrightness * 2.55);
  }
}
void animationMeteorRain() {
  static uint32_t lastUpdate = 0;
  static uint16_t step = 0;
  static int meteorPos[6] = {-1,-1,-1,-1,-1,-1};
  static int meteorLen[6];
  static uint8_t meteorHue[6];
  uint32_t now = millis();
  if (now - lastUpdate > max(8, 70 - currentSpeed)) {
    lastUpdate = now;
    fadeToBlackBy(leds, NUM_LEDS, 40);
    if (random8() < (50 + currentSpeed)) {
      for (int m = 0; m < 6; m++) {
        if (meteorPos[m] == -1) {
          meteorPos[m] = random16(NUM_LEDS);
          meteorLen[m] = random8(6, 24);
          meteorHue[m] = random8(); 
          break;
        }
      }
    }
    for (int m = 0; m < 6; m++) {
      if (meteorPos[m] >= 0) {
        meteorPos[m] = (meteorPos[m] + 1) % NUM_LEDS;
        for (int t = 0; t < meteorLen[m]; t++) {
          int idx = meteorPos[m] - t;
          if (idx < 0) idx += NUM_LEDS;
          uint8_t brightness = 255 - ((255 * t) / meteorLen[m]);
          leds[idx] += CHSV(meteorHue[m], 240, qmul8((uint8_t)brightness, (uint8_t)(currentBrightness * 2.55)));
        }
        if (random8() < 20) {
          int g = (meteorPos[m] + random8(6)) % NUM_LEDS;
          leds[g] += CHSV(meteorHue[m] + 30, 255, currentBrightness * 2.55);
        }
        if (random8() < 12 + currentSpeed/4 && meteorPos[m] > NUM_LEDS-5) {
          meteorPos[m] = -1;
        }
      }
    }
    if (random8() < 8) {
      int p = random16(NUM_LEDS);
      leds[p] += CHSV(random8(), 200, currentBrightness * 2.55);
    }
  }
}
void animationGradientWave() {
  static uint32_t lastUpdate = 0;
  static uint16_t t = 0;
  uint32_t now = millis();
  if (now - lastUpdate > max(6, 48 - currentSpeed)) {
    lastUpdate = now;
    t += 2 + (currentSpeed / 6);
    for (int i = 0; i < NUM_LEDS; i++) {
      uint16_t p = (i * 512 / max(1, NUM_LEDS)); 
      uint8_t hue = (uint8_t)((p + (t >> 1) + sin8(i * 2 + (t >> 3))) & 0xFF);
      uint8_t briWave = beatsin8(6 + (currentSpeed/10), 80, 255);
      uint8_t val = qmul8(briWave, (uint8_t)(currentBrightness * 2.55));
      leds[i] = CHSV(hue, 220, val);
    }
  }
}
void animationFire() {
  static uint32_t lastUpdate = 0;
  static uint8_t heat[NUM_LEDS];  
  static uint16_t fireTime = 0;
  uint32_t now = millis();
  if (now - lastUpdate < max(15, 40 - currentSpeed)) return;
  lastUpdate = now;
  fireTime += 3 + (currentSpeed / 8);
  for(int i = 0; i < NUM_LEDS / 8; i++) {
    int pos = random8(NUM_LEDS / 10); 
    uint8_t baseHeat = random8(100, 200) + random8(0, 55);
    heat[pos] = qadd8(heat[pos], baseHeat);
  }
  for(int i = NUM_LEDS - 1; i >= 2; i--) {
    heat[i] = (heat[i-1] + heat[i-2] + heat[i-2]) / 3;
  }
  for(int i = 0; i < NUM_LEDS; i++) {
    heat[i] = qsub8(heat[i], random8(5, 15));
  }
  if(random8() < 30 + (currentSpeed / 3)) {
    int sparkPos = random16(NUM_LEDS / 4, NUM_LEDS / 2);
    heat[sparkPos] = qadd8(heat[sparkPos], random8(100, 180));
  }
  for(int i = 0; i < NUM_LEDS; i++) {
    uint8_t temperature = heat[i];
    CRGB color;
    if(temperature < 60) {
      color = CRGB(10, 0, 0);
    }
    else if(temperature < 120) {
      uint8_t intensity = scale8(temperature - 60, 100);
      color = CRGB(intensity, 0, 0);
    }
    else if(temperature < 180) {
      uint8_t red = 255;
      uint8_t green = scale8(temperature - 120, 150);
      color = CRGB(red, green, 0);
    }
    else {
      uint8_t red = 255;
      uint8_t green = 255;
      uint8_t blue = scale8(temperature - 180, 100);
      color = CRGB(red, green, blue);
    }
    color.nscale8_video((uint8_t)(currentBrightness * 2.55));
    leds[i] = color;
  }
  uint8_t wave = beatsin8(6 + (currentSpeed / 15), 50, 150);
  for(int i = 0; i < NUM_LEDS; i++) {
    uint8_t waveEffect = sin8((i * 3) + (fireTime >> 2));
    leds[i].nscale8_video(scale8(waveEffect, wave));
  }
  FastLED.setBrightness((uint8_t)(currentBrightness * 2.55));
}
void animationPulseZones() {
  static uint32_t lastUpdate = 0;
  static uint16_t phase = 0;
  uint32_t now = millis();
  if (now - lastUpdate > max(6, 50 - currentSpeed)) {
    lastUpdate = now;
    phase += 3 + (currentSpeed / 6);
    int zones = constrain(NUM_LEDS / max(8, NUM_LEDS/5), 3, 8); 
    int zoneSize = max(1, NUM_LEDS / zones);
    for (int i = 0; i < NUM_LEDS; i++) {
      int z = i / zoneSize;
      uint8_t baseHue = (z * (256 / max(1, zones))) + (phase / 4);
      uint8_t wave = sin8((i * 6) + (phase >> (1 + (z%3))));
      uint8_t brightness = qmul8(wave, (uint8_t)(currentBrightness * 2.55));
      CRGB c = CHSV(baseHue + (i % 16), 240, brightness);
      if (random8() < (10 + currentSpeed/8)) {
        c += CHSV(baseHue + random8(40, 100), 255, currentBrightness * 2.55);
      }
      leds[i] = c;
    }
  }
}
void animationAurora() {
  static uint32_t lastUpdate = 0;
  static uint16_t t = 0;
  uint32_t now = millis();
  uint16_t speedFactor = max(1, (int)(101 - currentSpeed)); 
  if (now - lastUpdate > max(4, 40 - currentSpeed/2)) {
    lastUpdate = now;
    t += 1 + (currentSpeed / 25);
    for (int i = 0; i < NUM_LEDS; i++) {
      uint8_t layer1 = sin8((i * 2) + (t >> 2));
      uint8_t layer2 = sin8((i * 3) + (t >> 1));
      uint8_t layer3 = sin8((i * 4) + (t));
      CHSV baseHSV = rgb2hsv_approximate(currentColor);
      uint8_t h = baseHSV.h + (layer1 >> 3);
      uint8_t s = 200;
      uint8_t b = qmul8(qadd8(layer2, layer3), (uint8_t)(currentBrightness * 2.55 / 2));
      leds[i] = CHSV(h, s, b);
    }
    FastLED.setBrightness(max(1, (int)(currentBrightness * 2.55)));
  }
}
void animationMatrixRain() {
  struct Drop { float pos; float speed; uint8_t length; uint8_t hue; };
  const uint8_t MAX_DROPS = min(48, max(8, NUM_LEDS / 8)); 
  static Drop drops[48];
  static bool init = false;
  static uint32_t last = 0;
  uint32_t now = millis();
  if (!init) {
    init = true;
    for (uint8_t i = 0; i < MAX_DROPS; i++) {
      drops[i].pos = -random16(NUM_LEDS); 
      drops[i].speed = random8(6, 16) / 8.0f; 
      drops[i].length = random8(3, 18);
      drops[i].hue = 96 + random8(0, 40); 
    }
  }
  uint16_t frameDelay = max(8, 60 - currentSpeed); 
  if (now - last < frameDelay) return;
  last = now;
  for (int i = 0; i < NUM_LEDS; i++) leds[i].nscale8_video(230);
  for (uint8_t d = 0; d < MAX_DROPS; d++) {
    float spd = drops[d].speed * (1.0f + (currentSpeed / 100.0f));
    drops[d].pos += spd;
    if (drops[d].pos - drops[d].length > NUM_LEDS) {
      drops[d].pos = -random8(0, NUM_LEDS / 3);
      drops[d].speed = random8(6, 20) / 8.0f;
      drops[d].length = random8(3, 18);
      drops[d].hue = 80 + random8(0, 70);
    }
    int head = (int)floor(drops[d].pos);
    for (int s = 0; s < drops[d].length; s++) {
      int idx = head - s;
      if (idx < 0 || idx >= NUM_LEDS) continue;
      // parlaklık: head en parlak, tail azalır
      uint8_t bright = 255;
      if (s > 0) {
        bright = qsub8(255, (uint8_t)( (uint16_t)s * (180UL / max(1, (int)drops[d].length)) ));
      }
      uint8_t b = qmul8(bright, (uint8_t)(currentBrightness * 2.55));
      leds[idx] += CHSV(drops[d].hue, 200, b);
    }
  }
  FastLED.setBrightness(max(1, (int)(currentBrightness * 2.55)));
}
void animationTwinkle() {
  static uint32_t last = 0;
  uint32_t now = millis();
  if (now - last < max(8, 40 - currentSpeed)) return; 
  last = now;
  uint8_t density = constrain(6 + (currentSpeed / 5), 6, 140); 
  uint8_t baseBrightness = max(8, (int)(currentBrightness * 2.55));
  for (int i = 0; i < NUM_LEDS; i++) {
    uint16_t t = (uint16_t)(now >> 4); 
    uint16_t seed = (uint16_t)((i * 257) ^ t); 
    uint8_t chance = (uint8_t)(((seed >> 8) ^ (seed & 0xFF)) & 0xFF);
    if (random8() < density && (chance & 0x7F) < density) {
      uint8_t life = random8(120, 360); 
      uint8_t phase = (uint8_t)( (now >> 2) + (seed & 0xFF) );
      uint8_t env = sin8(phase); 
      uint8_t b = qmul8(env, baseBrightness);
      CHSV hsv = rgb2hsv_approximate(currentColor);
      uint8_t hueOff = hsv.h + (seed & 31) - 16; 
      leds[i] = leds[i] + CHSV(hueOff, min(255, hsv.s + 20), b);
    } else {
      leds[i].nscale8_video(245);
    }
  }
  FastLED.setBrightness(max(1, (int)(currentBrightness * 2.55)));
}
void animationRipples() {
  struct Ripple { int center; float radius; float speed; uint8_t hue; uint8_t life; bool active; };
  const uint8_t MAX_R = 6;
  static Ripple ripples[MAX_R];
  static bool inited = false;
  static uint32_t last = 0;
  uint32_t now = millis();
  if (!inited) {
    inited = true;
    for (uint8_t r = 0; r < MAX_R; r++) {
      ripples[r].active = false;
    }
  }
  if (now - last < max(6, 45 - currentSpeed)) return;
  last = now;
  for (int i = 0; i < NUM_LEDS; i++) leds[i].nscale8_video(240);
  // bazen yeni ripple başlat
  if (random8() < (40 + currentSpeed)) {
    for (uint8_t r = 0; r < MAX_R; r++) {
      if (!ripples[r].active) {
        ripples[r].active = true;
        ripples[r].center = random16(NUM_LEDS);
        ripples[r].radius = 0.0f;
        ripples[r].speed = (0.6f + (random8(60) / 100.0f)) * (1.0f + currentSpeed / 100.0f);
        ripples[r].hue = (uint8_t)(rgb2hsv_approximate(currentColor).h + random8(0,40) - 20);
        ripples[r].life = 255;
        break;
      }
    }
  }
  for (uint8_t r = 0; r < MAX_R; r++) {
    if (!ripples[r].active) continue;
    ripples[r].radius += ripples[r].speed;
    ripples[r].life = qsub8(ripples[r].life, 2 + (currentSpeed / 40));
    int center = ripples[r].center;
    float rad = ripples[r].radius;
    int rippleWidth = max(3, (int)(5 + currentSpeed / 20)); 
    int start = (int)floor(rad) - rippleWidth - 1;
    int end = (int)ceil(rad) + rippleWidth + 1;
    for (int d = start; d <= end; d++) {
      int pos = center + d;
      // wrap-around
      while (pos < 0) pos += NUM_LEDS;
      while (pos >= NUM_LEDS) pos -= NUM_LEDS;
      int dist = abs(d);
      uint8_t fall = 255;
      int denom = max(1, rippleWidth + abs((int)rad)/6);
      fall = qsub8(255, (uint8_t)( (uint16_t)dist * 200UL / denom ));
      uint8_t mod = sin8((uint8_t)(dist * 12 + (uint8_t)rad*3));
      uint8_t b = qmul8(qmul8(fall, mod), (uint8_t)(currentBrightness * 2.55));
      leds[pos] += CHSV(ripples[r].hue, 220, b);
    }
    if (ripples[r].life < 8 || rad > (NUM_LEDS + 50)) {
      ripples[r].active = false;
    }
  }
  FastLED.setBrightness(max(1, (int)(currentBrightness * 2.55)));
}
// Animasyonu güncelle
void updateAnimation() {
  switch (currentAnimation) {
    case ANIM_SOLID: animationSolid(); break;
    case ANIM_PULSE: animationPulse(); break;
    case ANIM_THEATER: animationTheaterChase(); break;
    case ANIM_RAINBOW: animationRainbow(); break;
    case ANIM_SCANNER: animationLarsonScanner(); break;
    case ANIM_COMET: animationComet(); break;
    case ANIM_METEOR: animationMeteorRain(); break;
    case ANIM_GRADIENT: animationGradientWave(); break;
    case ANIM_FIRE: animationFire(); break;
    case ANIM_ZONES: animationPulseZones(); break;
    case ANIM_AURORA: animationAurora(); break;
    case ANIM_MATRIX: animationMatrixRain(); break;
    case ANIM_TWINKLE: animationTwinkle(); break;
    case ANIM_RIPPLES: animationRipples(); break;
