// ==================== LOGLAMA FONKSİYONLARI ====================

// Yeni log mesajı ekler
void addLog(String message) {
    // Zaman damgası ekle
    unsigned long secs = millis() / 1000;
    unsigned long mins = secs / 60;
    unsigned long hrs = mins / 60;
    char timestampBuf[12]; // HH:MM:SS -
    sprintf(timestampBuf, "%02lu:%02lu:%02lu - ", hrs % 24, mins % 60, secs % 60);
    String logEntry = String(timestampBuf) + message;


    state.logBuffer[state.logBufferIndex] = logEntry;
    state.logBufferIndex = (state.logBufferIndex + 1) % LOG_BUFFER_SIZE;
    Serial.println(logEntry); // Seriyele de yazdır

    // Yeni log mesajını bağlı tüm WS istemcilerine gönder
    if (ws.count() > 0) {
        DynamicJsonDocument doc(message.length() + 100); // JSON overhead için pay bırak
        doc["type"] = "log_update";
        doc["message"] = logEntry;
        String output;
        serializeJson(doc, output);
        ws.textAll(output);
    }
}

// Tüm logları JSON formatında döndürür
String getLogsJson() {
    DynamicJsonDocument doc(LOG_BUFFER_SIZE * 150 + 100); // Buffer boyutuna göre ayarla
    doc["type"] = "logs";
    JsonArray logsArray = doc.createNestedArray("logs");

    // Logları doğru sırada (eskiden yeniye) ekle
    int startIndex = state.logBufferIndex; // En son eklenenin bir sonrası (boş veya en eski)
    for (int i = 0; i < LOG_BUFFER_SIZE; ++i) {
        int currentIndex = (startIndex + i) % LOG_BUFFER_SIZE;
        if (state.logBuffer[currentIndex].length() > 0) { // Boş olmayanları ekle
            logsArray.add(state.logBuffer[currentIndex]);
        }
    }

    String output;
    serializeJson(doc, output);
    return output;
}


// ==================== SENSÖR OKUMA & İŞLEME ====================

void processRadar() {
    state.rawRadarAmplitude = sensorManager.getRawRadarValue();
    state.smoothedRadarAmplitude = sensorManager.getSmoothedRadarValue();
    uint16_t motionThresholdValue = config.radarNoiseFloor + config.motionThresholdAmplitude;
    bool previousMotionState = state.motionDetected;

    // Hareket algılama (yumuşatılmış değer ve eşik kullanılarak)
    if (state.smoothedRadarAmplitude > motionThresholdValue) {
        // Eşiğin üzerindeyse hareket var sayılır
        if (!state.motionDetected) {
           // Yeni hareket algılandı
           addLog("Hareket algilandi (Amp: " + String(state.smoothedRadarAmplitude) + " > " + String(motionThresholdValue) + ")");
           state.motionDetected = true;
        }
         state.lastMotionDetectedTime = millis(); // Hareket görüldüğü sürece zamanı güncelle
    } else {
        // Eşiğin altındaysa ve belirli bir süre geçtiyse hareketi durdur
        if (state.motionDetected && (millis() - state.lastMotionDetectedTime > 500)) { // 500ms bekleme süresi
            addLog("Hareket durdu (Timeout)");
            state.motionDetected = false;
        }
        // Eğer eşiğin altına yeni düştüyse, timeout süresi başlayacak
    }


    // Hareket varsa mesafe tahmini ve LED pozisyonu hesapla
    if (state.motionDetected || (millis() - state.lastMotionDetectedTime < MOTION_TIMEOUT_MS)) { // Timeout süresince de pozisyonu tut
        state.estimatedDistanceMeters = sensorManager.calculateDistance(state.smoothedRadarAmplitude, config);

        // Kalibrasyon geçerliliğini kontrol et (SensorManager'dan gelen bilgiye göre değil, config'e göre)
        // Mesafe arttıkça genlik artmalı! (ESP-Radar datasheet'ine göre)
        state.calibrationInvalid = !(config.radarAmplitudeAt5m >= config.radarAmplitudeAt3m &&
                                     config.radarAmplitudeAt3m >= config.radarAmplitudeAt1m &&
                                     config.radarAmplitudeAt1m > config.radarNoiseFloor); // Eşitlik kabul edilebilir ama > daha iyi

        if (state.calibrationInvalid) {
             // Kalibrasyon hatasını logla (çok sık olmasın)
            static uint32_t lastCalibErrorLog = 0;
            if(millis() - lastCalibErrorLog > 300000){ // 5 dakikada bir
                addLog("HATA: Radar kalibrasyon değerleri geçersiz/hatalı sıralı!");
                lastCalibErrorLog = millis();
            }
            state.estimatedDistanceMeters = -1.0f; // Geçersiz kalibrasyonda mesafe hesaplama
            state.targetPositionLED = -1.0f; // Hedef pozisyonu sıfırla
            // state.currentPositionLED = -1.0f; // Mevcut pozisyonu da sıfırlayabiliriz veya son bilinen yerde kalabilir
        } else {
            // Geçerli kalibrasyon ve mesafe
            if (state.estimatedDistanceMeters >= 0.0f) {
                // Mesafeyi LED pozisyonuna çevir
                state.targetPositionLED = mapFloat(state.estimatedDistanceMeters, 0.0f, CORRIDOR_LENGTH_M, 0.0f, (float)NUM_LEDS - 1.0f);
                state.targetPositionLED = constrain(state.targetPositionLED, 0.0f, (float)NUM_LEDS - 1.0f);

                // LED pozisyonunu yumuşat (hedefe doğru hareket)
                if (state.currentPositionLED < 0.0f || !previousMotionState) {
                    // İlk hareket algılandığında veya uzun süre sonra tekrar algılandığında direkt hedefe atla
                    state.currentPositionLED = state.targetPositionLED;
                } else {
                    // Yumuşak geçiş
                    state.currentPositionLED = (state.targetPositionLED * POSITION_SMOOTHING) + (state.currentPositionLED * (1.0f - POSITION_SMOOTHING));
                }
            } else {
                 // Mesafe hesaplanamadı (gürültü altında veya kalibrasyon dışı) ama hareket var
                 state.targetPositionLED = -1.0f;
                 // state.currentPositionLED'i ne yapmalı? Belki son bilinen pozisyonda tutabiliriz.
            }
        }
    } else {
        // Hareket yok (ve timeout süresi doldu)
        state.estimatedDistanceMeters = -1.0;
        state.targetPositionLED = -1.0;
        // state.currentPositionLED = -1.0; // Hareket bitince pozisyonu sıfırla
    }
}

// ==================== DURUM YÖNETİMİ ====================

void updateSystemState() {
    // Sensör durumlarını al
    state.currentLux = sensorManager.getCurrentLux();
    state.tslSensorOk = sensorManager.isLightSensorWorking();

    // Sistem bilgilerini güncelle
    state.freeHeap = ESP.getFreeHeap();
    state.uptimeSeconds = millis() / 1000;

    // Işık seviyesine göre modları belirle
    if (!state.tslSensorOk) {
        // Sensör çalışmıyorsa, her zaman akşam modunda varsayalım
        state.isEvening = true;
        state.isSleepTime = false; // Uyku modunu aktif etme
         // Sensör hatasını logla (çok sık olmasın)
         static uint32_t lastTslErrorLog = 0;
         if (millis() - lastTslErrorLog > 300000) { // 5 dakikada bir
             addLog("UYARI: TSL2561 ışık sensörü okunamıyor, Akşam modu varsayılıyor.");
             lastTslErrorLog = millis();
         }
    } else {
        // Sensör çalışıyor, normal kontrol
        state.isEvening = (state.currentLux < config.eveningThresholdLux);
        state.isSleepTime = (state.isEvening && (state.currentLux < config.sleepThresholdLux));
    }

    // Işıkların açık olup olmayacağını belirle
    // Hareket varsa VEYA hareket yeni bittiyse (timeout süresi içindeyse) ışıkları açık tut
    bool motionActive = state.motionDetected || (millis() - state.lastMotionDetectedTime < MOTION_TIMEOUT_MS);
    // Işıkların yanması için hem akşam/uyku modu aktif olmalı hem de hareket olmalı
    bool shouldBeOn = (state.isEvening || state.isSleepTime) && motionActive;

    // Durum değişikliğini logla
    if (shouldBeOn && !state.lightsOn) {
        String modeStr = state.isSleepTime ? "Uyku" : (state.tslSensorOk ? "Akşam" : "Akşam(Sensör Yok)");
        addLog("Isiklar AÇILIYOR. Mod: " + modeStr + " (Lux: " + String(state.currentLux, 1) + ")");
        state.lightsOn = true;
        // Parlaklığı sıfırdan başlatıp fade-in yapacağız (updateLeds içinde)
        // state.currentBrightness = 0; // updateLeds içinde yönetiliyor
    }
    else if (!shouldBeOn && state.lightsOn) {
        addLog("Isiklar KAPANIYOR. (Hareket Bitti veya Gündüz)");
        state.lightsOn = false;
    }

    // Kalibrasyon durumunu tekrar kontrol et (processRadar içinde de ediliyor ama burada da olabilir)
     state.calibrationInvalid = !(config.radarAmplitudeAt5m >= config.radarAmplitudeAt3m &&
                                  config.radarAmplitudeAt3m >= config.radarAmplitudeAt1m &&
                                  config.radarAmplitudeAt1m > config.radarNoiseFloor);
}


// ==================== LED KONTROL FONKSİYONLARI ====================

// LED'leri mevcut duruma göre günceller
void updateLeds() {
    unsigned long currentMillis = millis();
    // LED güncelleme sıklığını kontrol et (~30 FPS)
    if (currentMillis - state.lastLedUpdateTime < LED_UPDATE_INTERVAL_MS) {
        return; // Henüz güncelleme zamanı gelmedi
    }
    state.lastLedUpdateTime = currentMillis;

    if (!state.lightsOn) {
        // Işıklar kapalıysa, yavaşça söndür
        ledControl.fadeToBlack(40); // Karartma hızı (scale değeri)
        // Parlaklık sıfırsa tekrar ayarlamaya gerek yok
        if (FastLED.getBrightness() > 0) {
            // Tamamen söndüğünden emin ol
            bool allOff = true;
            for(int i=0; i<NUM_LEDS; ++i) {
                if (leds[i]) { allOff = false; break;}
            }
            if (allOff) {
                 FastLED.setBrightness(0);
                 state.currentBrightness = 0;
            }
        }
    } else {
        // Işıklar AÇIK
        // Hedef parlaklığı belirle (mod'a göre)
        uint8_t targetBrightness = state.isSleepTime ? config.nightBrightness : config.normalBrightness;
        uint8_t currentLedLibBrightness = FastLED.getBrightness(); // Kütüphanenin parlaklığı

        // Geçiş hızına göre parlaklığı ayarla (fade-in / fade-out)
        uint8_t step = map(config.transitionSpeed, 1, 20, 1, 15); // Geçiş hızını map ile adıma çevir
        uint8_t newBrightness = currentLedLibBrightness;

        if (currentLedLibBrightness < targetBrightness) {
            newBrightness = safe_min(targetBrightness, (uint8_t)(currentLedLibBrightness + step));
        } else if (currentLedLibBrightness > targetBrightness) {
            newBrightness = safe_max(targetBrightness, (uint8_t)(currentLedLibBrightness - step));
        }

        // Parlaklığı uygula (değiştiyse)
        if (newBrightness != currentLedLibBrightness) {
            FastLED.setBrightness(newBrightness);
        }
        state.currentBrightness = newBrightness; // Sistem durumu parlaklığını güncelle

        // Hedef rengi belirle
        CHSV color = state.isSleepTime
                     ? CHSV(config.nightHue, config.nightSat, 255) // Gece modu rengi (parlaklık FastLED ile ayarlanıyor)
                     : CHSV(0, 0, 255); // Normal/Akşam modu (Beyaz, parlaklık FastLED ile)

        // Mevcut efekti al
        EffectType effect = (EffectType)config.currentEffect;
        float position = state.currentPositionLED; // Yumuşatılmış LED pozisyonu
        uint16_t segment = config.ledSegmentLength;

        // Efekti uygula
        if (position >= 0.0f) { // Geçerli bir pozisyon varsa
            switch(effect) {
                case EFFECT_SIMPLE:  ledControl.simpleEffect(position, segment, color); break;
                case EFFECT_TRAIL:   ledControl.trailEffect(position, segment, color); break;
                case EFFECT_PULSE:   ledControl.pulseEffect(position, segment, color); break;
                case EFFECT_RAINBOW: ledControl.rainbowEffect(position, segment); break; // Renk parametresi yok
                case EFFECT_THEATER: ledControl.theaterChaseEffect(position, segment, color); break;
                default:             ledControl.simpleEffect(position, segment, color); break; // Bilinmeyen efekt -> Basit
            }
        } else if (state.motionDetected) {
            // Pozisyon hesaplanamadı ama hareket var (örn. kalibrasyon hatası)
            // Belki tüm koridoru yakabiliriz? Veya segmenti başlangıçta?
            // Şimdilik tüm koridoru yakmayı deneyelim
             fill_solid(leds, NUM_LEDS, color);
             // Veya sadece başlangıç segmentini yak:
             // ledControl.simpleEffect(0.0f, segment, color);
        } else {
            // Pozisyon yok ve hareket yok (bu durum updateSystemState kontrolünden sonra olmamalı ama garanti)
            ledControl.fadeToBlack(30);
        }
    }

    // Hesaplanan LED renklerini ve parlaklığı fiziksel şeride gönder
    FastLED.show();
}

// Tüm LED'leri belirli bir renge ayarlar (genellikle başlangıç ve özel durumlar için)
void setAllLEDs(CRGB color) {
    if (!leds) return;
    fill_solid(leds, NUM_LEDS, color);
    // FastLED.show() burada çağrılmalı mı? Genellikle evet.
    FastLED.show();
}


