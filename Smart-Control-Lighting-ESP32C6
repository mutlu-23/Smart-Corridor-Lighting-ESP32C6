// Değeri bir aralıktan diğerine haritalar (float)
float mapFloat(float x, float in_min, float in_max, float out_min, float out_max) {
    // Bölme sıfır hatasını önle
    if (abs(in_max - in_min) < 1e-6) { // Çok küçük bir sayı (epsilon)
        return out_min; // Veya ortalama (out_min + out_max) / 2.0f;
    }
    // Lineer haritalama formülü
    return (x - in_min) * (out_max - out_min) / (in_max - in_min) + out_min;
}

// WiFi bağlantısını kontrol eder ve gerekirse yeniden bağlanmayı dener
void checkWifiConnection() {
     if (state.apMode) return; // AP modundaysa kontrol etme

     unsigned long currentMillis = millis();
     // Bağlantı koptuysa ve yeniden bağlanma zamanı geldiyse
     if (WiFi.status() != WL_CONNECTED && currentMillis - state.lastReconnectAttempt > WIFI_RECONNECT_INTERVAL_MS) {
        addLog("WiFi baglantisi koptu, yeniden baglanma denemesi...");
        state.wifiConnected = false;
        // OTA aktifiz ve WiFi koparsa, OTA'yı durdurmak gerekebilir mi? Şimdilik hayır.
        state.lastReconnectAttempt = currentMillis;
        WiFi.disconnect(); // Önce bağlantıyı kes
        delay(100); // Kısa bekleme
        WiFi.mode(WIFI_STA); // STA modunu tekrar ayarla (gerekli mi?)
        WiFi.setHostname(HOSTNAME); // Hostname'i tekrar ayarla
        WiFi.begin(config.wifi_ssid, config.wifi_password); // Kayıtlı bilgilerle tekrar dene
        Serial.print("Yeniden baglaniliyor");
     } else if (WiFi.status() != WL_CONNECTED && state.wifiConnected) {
         // Henüz reconnect interval dolmadı ama bağlantı yok, durumu false yap
         // Bu durum, loop içinde WiFi.status() her kontrol edildiğinde log spam yapabilir.
         // Sadece interval dolduğunda log atmak daha iyi.
         // state.wifiConnected = false; // Bunu yapmayalım, sadece interval'de log atalım.
         if(Serial.availableForWrite()) { // Prevent blocking if Serial buffer is full
             Serial.print("."); // Bağlanma sırasında nokta yazdırmaya devam et (çok sık yazdırmamaya dikkat)
         }
     }
     else if (WiFi.status() == WL_CONNECTED && !state.wifiConnected) {
         // Bağlantı başarılı oldu (ilk bağlantı veya yeniden bağlantı)
         state.wifiConnected = true;
         IPAddress ip = WiFi.localIP();
         addLog("WiFi yeniden baglandi. IP: " + ip.toString());
         Serial.println("\nWiFi yeniden baglandi! IP: " + ip.toString());
         // OTA'yı (yeniden) başlat
         setupOTA();
     }
}
